# ArenaPulse backend configuration
# Copy to .env and fill in. Everything is optional — the app runs fully in
# fallback mode with nothing set (heuristic planner, in-memory vendors).

# --- Gemini 3 (the agent brain) ---
# Option A: Vertex AI (the hackathon path — Agent Builder / ADK + Cloud Run)
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Option B: AI Studio (simple local dev) — leave Vertex flag false and set a key
# GOOGLE_GENAI_USE_VERTEXAI=false
# GEMINI_API_KEY=your-ai-studio-key
# Set to the exact Gemini 3 model id available in your project:
GEMINI_MODEL=gemini-3-pro-preview

# --- Elastic (partner MCP track) ---
# Elastic Cloud trial endpoint + API key, used for vendor/inventory/RAG search.
ELASTICSEARCH_URL=http://localhost:9200
# ELASTIC_API_KEY=your-elastic-api-key

# --- Arize Phoenix (secondary observability integration) ---
# Point to a local Phoenix server or Arize AX cloud endpoint.
# Leave unset to disable tracing (no startup warnings).
# Local Phoenix: http://localhost:6006/v1/traces  (run: python -m phoenix.server.main serve)
# Arize AX cloud: https://app.arize.com/v1/traces (needs PHOENIX_API_KEY below)
# PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
# PHOENIX_API_KEY=your-arize-ax-api-key  # only needed for Arize AX cloud (M6)

# --- Simulator / agent behaviour ---
SIMULATION_ACTIVE=true
SIMULATION_INTERVAL_SECONDS=5
DRY_RUN=true

# --- Agent Builder / ADK ---
# When true (and google-adk + Gemini are configured) the planning brain runs as
# an ADK LlmAgent that can call the Elastic vendor-search tool. Falls back to
# direct Gemini, then heuristic. Safe to leave true — it no-ops without creds.
USE_ADK=true

# Official Elastic MCP server SSE endpoint.
# When set, the ADK agent registers the official Elastic MCPToolset (in addition
# to the local find_nearby_vendors FunctionTool). Gemini will prefer native
# elasticsearch_search calls via the MCP server for the vendor geo-search.
# Run the Elastic MCP server Docker image first:
#   docker run -p 3001:3001 \
#     -e ES_URL=$ELASTICSEARCH_URL \
#     -e ES_API_KEY=$ELASTIC_API_KEY \
#     docker.elastic.co/integrations/mcp-server-elasticsearch:latest
# Then set:
# ELASTIC_MCP_URL=http://localhost:3001/sse

# --- Human-in-the-loop oversight ---
# When true, high-impact actions are held as PENDING_APPROVAL until a human
# resolves them via POST /api/v1/approvals/{event_id}.
APPROVAL_REQUIRED=false
APPROVAL_RESOURCE_THRESHOLD=5000
